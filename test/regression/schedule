# pg_duckpipe regression test schedule
# Auto-start test (must run first on fresh instance with no worker)
test: auto_start
# API and monitoring tests (no background worker needed)
test: api
test: monitoring
test: metrics
test: sync_group_mode
test: group_config
test: table_config
# Nonexistent table: proper error message instead of misleading "no primary key"
test: nonexistent_table
# Access control: target table grants, function privileges
test: acl
# Streaming CDC tests (require background worker)
test: streaming
test: snapshot_updates
test: multiple_tables
test: data_types
test: resync
test: truncate
test: stress_append
# TOAST unchanged columns become NULL (bug confirmation test)
test: toast_unchanged
# REPLICA IDENTITY FULL opt-in (ALTER TABLE on add, full-row WAL, no TOAST resolution needed)
test: replica_identity_full
# Single-table mixed DML (INSERT + UPDATE + DELETE in same flush)
test: mixed_dml
# Composite primary keys (multi-column PK UPDATE/DELETE)
test: composite_pk
# Partitioned source table support (publish_via_partition_root)
test: partitioned_table
# Large single transaction (mid-txn flush triggers)
test: large_transaction
# Concurrent parallel flush across 5 tables (std::thread::scope)
test: concurrent_tables
# Multiple independent sync groups
test: multi_group
# Fan-in streaming: multiple sources → single target
test: fan_in
# Error detection and recovery via resync
test: error_recovery
# Snapshot error recovery with exponential backoff and auto-retry
test: snapshot_error_recovery
# Shutdown recovery: rows dropped from in-memory accumulator are re-delivered on restart
test: shutdown_recovery
# Table rename with OID-based routing
test: rename_table
# Premature CATCHUP→STREAMING transition (many separate transactions)
test: premature_catchup
# WAL buffering during snapshot (paused flush queue correctness)
test: snapshot_buffering
# Snapshot with special characters (CSV escaping: commas, quotes, newlines, Unicode)
test: snapshot_special_chars
# Snapshot race condition proof (uses background psql session)
test: snapshot_race
# LISTEN/NOTIFY wakeup (worker wakes immediately on add_table with long poll_interval)
test: notify_wakeup
# Removing a table must not hold back confirmed_lsn for remaining tables
test: remove_table_lag
# JSONB column type mapping (PG jsonb → DuckDB JSON)
test: jsonb_type
# Append sync mode: immutable changelog with _duckpipe_op and _duckpipe_lsn
test: append_mode
# Append sync mode for tables with no primary key
test: append_mode_no_pk
# Append-mode crash recovery: dedup via MAX(_duckpipe_lsn) high-water mark
test: append_crash_recovery
# Remote sync: loopback TCP exercises tokio-postgres DDL path
test: remote_sync
# ducklake_catalog_connstr: config CRUD + E2E flush through configured connstr
test: ducklake_catalog_connstr
# Transparent query routing: planner hook rewrites SELECTs to DuckLake targets
test: query_routing
# DDL sync: ADD/DROP/RENAME COLUMN propagated to DuckLake target
test: ddl_sync
