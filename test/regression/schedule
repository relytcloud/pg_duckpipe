# pg_duckpipe regression test schedule
# Auto-start test (must run first on fresh instance with no worker)
test: auto_start
# API and monitoring tests (no background worker needed)
test: api
test: monitoring
# Streaming CDC tests (require background worker)
test: streaming
test: snapshot_updates
test: multiple_tables
test: data_types
test: resync
test: truncate
test: stress_append
# TOAST unchanged columns become NULL (bug confirmation test)
test: toast_unchanged
# REPLICA IDENTITY FULL opt-in (ALTER TABLE on add, full-row WAL, no TOAST resolution needed)
test: replica_identity_full
# Single-table mixed DML (INSERT + UPDATE + DELETE in same flush)
test: mixed_dml
# Composite primary keys (multi-column PK UPDATE/DELETE)
test: composite_pk
# Large single transaction (mid-txn flush triggers)
test: large_transaction
# Concurrent parallel flush across 5 tables (std::thread::scope)
test: concurrent_tables
# Multiple independent sync groups
test: multi_group
# Error detection and recovery via resync
test: error_recovery
# Shutdown recovery: rows dropped from in-memory accumulator are re-delivered on restart
test: shutdown_recovery
# Table rename with OID-based routing
test: rename_table
# Premature CATCHUP→STREAMING transition (many separate transactions)
test: premature_catchup
# WAL buffering during snapshot (paused flush queue correctness)
test: snapshot_buffering
# Snapshot with special characters (CSV escaping: commas, quotes, newlines, Unicode)
test: snapshot_special_chars
# Snapshot race condition proof (uses background psql session)
test: snapshot_race
