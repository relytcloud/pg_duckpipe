(1 row)

SELECT duckpipe.remove_table('public.stream_test', false);
 remove_table 
--------------
 
(1 row)

DROP TABLE public.stream_test_ducklake;
DROP TABLE stream_test;
SET client_min_messages = warning;
SELECT duckpipe.stop_worker();
