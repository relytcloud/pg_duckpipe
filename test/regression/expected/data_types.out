-- Test various PostgreSQL data types
CREATE EXTENSION pg_duckpipe CASCADE;
SELECT duckpipe.start_worker();
NOTICE:  Background worker started for database regression
 start_worker 
--------------
 
(1 row)

CREATE TABLE dtype_test (
    id serial primary key,
    col_int int,
    col_bigint bigint,
    col_smallint smallint,
    col_float float,
    col_double double precision,
    col_text text,
    col_varchar varchar(100),
    col_bool boolean,
    col_ts timestamp,
    col_date date
);
SELECT duckpipe.add_table('public.dtype_test', NULL, 'default', false);
 add_table 
-----------
 
(1 row)

-- Insert rows with various types
INSERT INTO dtype_test (col_int, col_bigint, col_smallint, col_float, col_double, col_text, col_varchar, col_bool, col_ts, col_date)
VALUES (42, 9999999999, 1, 3.14, 2.718281828, 'hello world', 'varchar val', true, '2024-01-15 10:30:00', '2024-01-15');
-- Insert with NULLs
INSERT INTO dtype_test (col_int, col_bigint, col_smallint, col_float, col_double, col_text, col_varchar, col_bool, col_ts, col_date)
VALUES (NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL);
-- Insert with empty string
INSERT INTO dtype_test (col_int, col_text, col_varchar)
VALUES (0, '', '');
SELECT pg_sleep(2);
 pg_sleep 
----------
 
(1 row)

SELECT id, col_int, col_bigint, col_smallint, col_bool, col_text, col_varchar FROM public.dtype_test_ducklake ORDER BY id;
 id | col_int | col_bigint | col_smallint | col_bool |  col_text   | col_varchar 
----+---------+------------+--------------+----------+-------------+-------------
  1 |      42 | 9999999999 |            1 | t        | hello world | varchar val
  2 |         |            |              |          |             | 
  3 |       0 |            |              |          |             | 
(3 rows)

SELECT duckpipe.remove_table('public.dtype_test', false);
 remove_table 
--------------
 
(1 row)

DROP TABLE public.dtype_test_ducklake;
DROP TABLE dtype_test;
SET client_min_messages = warning;
SELECT duckpipe.stop_worker();
 stop_worker 
-------------
 
(1 row)

RESET client_min_messages;
DROP EXTENSION pg_duckpipe CASCADE;
