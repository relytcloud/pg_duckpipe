-- Test resync_table functionality
SELECT duckpipe.start_worker();
NOTICE:  Started 1 background worker(s)
 start_worker 
--------------
 
(1 row)

CREATE TABLE resync_src (id int primary key, val text);
INSERT INTO resync_src VALUES (1, 'one'), (2, 'two');
SELECT duckpipe.add_table('public.resync_src');
 add_table 
-----------
 
(1 row)

SELECT pg_sleep(2);
 pg_sleep 
----------
 
(1 row)

-- Verify initial snapshot
SELECT * FROM public.resync_src_ducklake ORDER BY id;
 id | val |     _duckpipe_source      
----+-----+---------------------------
  1 | one | default/public.resync_src
  2 | two | default/public.resync_src
(2 rows)

-- Modify source data directly
INSERT INTO resync_src VALUES (3, 'three');
SELECT pg_sleep(2);
 pg_sleep 
----------
 
(1 row)

-- Now trigger resync
SELECT duckpipe.resync_table('public.resync_src');
NOTICE:  Table 'public.resync_src' marked for resync
 resync_table 
--------------
 
(1 row)

SELECT pg_sleep(3);
 pg_sleep 
----------
 
(1 row)

-- Verify target has current source data
SELECT * FROM public.resync_src_ducklake ORDER BY id;
 id |  val  |     _duckpipe_source      
----+-------+---------------------------
  1 | one   | default/public.resync_src
  2 | two   | default/public.resync_src
  3 | three | default/public.resync_src
(3 rows)

SELECT duckpipe.remove_table('public.resync_src', false);
WARNING:  Group 'default' has no remaining tables — its replication slot is still holding WAL. Run SELECT duckpipe.drop_group('default') to release it.
 remove_table 
--------------
 
(1 row)

DROP TABLE public.resync_src_ducklake;
DROP TABLE resync_src;
SET client_min_messages = warning;
SELECT duckpipe.stop_worker();
 stop_worker 
-------------
 
(1 row)

RESET client_min_messages;
